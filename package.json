{
	"name": "loescher-erp",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"pdf": "node scripts/generate-pdf.ts",
		"pdf:all": "node scripts/generate-pdf.ts",
		"pdf:invoice": "node scripts/generate-pdf.ts --doc invoice --brand alrein --customer mahler",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:seed": "node scripts/seed.ts",
		"db:studio": "drizzle-kit studio",
		"auth:schema": "better-auth generate --config src/lib/server/auth.cli.ts --output src/lib/server/db/auth.schema.ts --yes",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:unit": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"test:e2e:pdf": "playwright test tests/e2e/pdf.spec.ts",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:visual": "playwright test visual",
		"test:e2e:update-snapshots": "playwright test --update-snapshots",
		"test:e2e:install": "playwright install --with-deps chromium",
		"verify": "pnpm lint && pnpm check && pnpm test:unit && pnpm build",
		"verify:quick": "pnpm lint && pnpm check && pnpm test:unit",
		"verify:full": "pnpm verify && pnpm test:e2e",
		"start": "node build/index.js"
	},
	"devDependencies": {
		"@better-auth/cli": "~1.4.21",
		"@eslint/js": "^10.0.1",
		"@fontsource-variable/outfit": "^5.2.8",
		"@inlang/paraglide-js": "^2.18.2",
		"@internationalized/date": "^3.12.2",
		"@internationalized/number": "^3.6.6",
		"@libsql/client": "^0.17.3",
		"@lucide/svelte": "^1.21.0",
		"@playwright/test": "~1.60.0",
		"@sveltejs/adapter-node": "next",
		"@sveltejs/enhanced-img": "^0.11.0",
		"@sveltejs/kit": "next",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tabler/icons-svelte": "^3.44.0",
		"@tailwindcss/vite": "^4.3.0",
		"@tanstack/table-core": "^8.21.3",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.4.1",
		"@testing-library/user-event": "^14.6.1",
		"@types/geojson": "^7946.0.16",
		"@types/node": "^24",
		"@types/testing-library__jest-dom": "^6.0.0",
		"@vitest/coverage-v8": "^4.1.9",
		"better-auth": "~1.4.21",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"embla-carousel-svelte": "^8.6.0",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"formsnap": "^2.0.1",
		"globals": "^17.6.0",
		"jsdom": "^29.1.1",
		"layerchart": "2.0.0-next.48",
		"mode-watcher": "^1.1.0",
		"paneforge": "^1.0.2",
		"playwright": "^1.60.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"shadcn-svelte": "^1.3.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"svelte-sonner": "^1.1.1",
		"sveltekit-superforms": "^2.30.1",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vaul-svelte": "1.0.0-next.7",
		"vite": "^8.0.16",
		"vitest": "^4.1.9"
	},
	"dependencies": {
		"@fontsource-variable/geist-mono": "^5.2.8",
		"@hugeicons/core-free-icons": "^4.2.1",
		"@hugeicons/svelte": "^1.1.3",
		"maplibre-gl": "^5.24.0",
		"phosphor-svelte": "^3.1.0"
	}
}
